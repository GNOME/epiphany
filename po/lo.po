#: data/org.gnome.Epiphany.desktop.in.in:2
#: data/org.gnome.Epiphany.metainfo.xml.in.in:6 embed/ephy-about-handler.c:205
#: embed/ephy-about-handler.c:237 src/ephy-main.c:104 src/ephy-main.c:268
#: src/ephy-main.c:429 src/window-commands.c:1230
msgid "Web"
msgstr "ເວັບ"

#: data/org.gnome.Epiphany.desktop.in.in:3
msgid "Web Browser"
msgstr "ຕົວທ່ອງເວັບ"

#: data/org.gnome.Epiphany.desktop.in.in:4
#: data/org.gnome.Epiphany.metainfo.xml.in.in:7
msgid "Browse the web"
msgstr "ທ່ອງເວັບ"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Epiphany.desktop.in.in:6
msgid "web;browser;internet;epiphany;"
msgstr "ເວັບ;ຕົວທ່ອງເວັບ;ອິນເຕີເນັດ;epiphany;"

#: data/org.gnome.Epiphany.desktop.in.in:20
msgid "New Window"
msgstr "ປ່ອງຢ້ຽມໃໝ່"

#: data/org.gnome.Epiphany.desktop.in.in:24
msgid "New Incognito Window"
msgstr "ປ່ອງຢ້ຽມບໍ່ລະບຸຕົວຕົນໃໝ່"

#: data/org.gnome.epiphany.gschema.xml:13
msgid "Browse with caret"
msgstr "ທ່ອງເວັບດ້ວຍແຄເຣັດ"

#: data/org.gnome.epiphany.gschema.xml:17
msgid "Home page"
msgstr "ໜ້າທຳອິດ"

#: data/org.gnome.epiphany.gschema.xml:18
msgid "Address of the user’s home page."
msgstr "ທີ່ຢູ່ຂອງໜ້າທຳອິດຂອງຜູ້ໃຊ້."

#: data/org.gnome.epiphany.gschema.xml:22
msgid "Default search engine"
msgstr "ເຄື່ອງມືຄົ້ນຫາເລີ່ມຕົ້ນ"

#: data/org.gnome.epiphany.gschema.xml:23
msgid "Name of the search engine selected by default."
msgstr "ຊື່ຂອງເຄື່ອງມືຄົ້ນຫາທີ່ຖືກເລືອກເປັນຄ່າເລີ່ມຕົ້ນ."

#: data/org.gnome.epiphany.gschema.xml:27
msgid "Incognito search engine"
msgstr "ເຄື່ອງມືຄົ້ນຫາໃນໂໝດບໍ່ລະບຸຕົວຕົນ"

#: data/org.gnome.epiphany.gschema.xml:28
msgid "Name of the search engine selected in incognito mode."
msgstr "ຊື່ຂອງເຄື່ອງມືຄົ້ນຫາທີ່ຖືກເລືອກໃນໂໝດບໍ່ລະບຸຕົວຕົນ."

#: data/org.gnome.epiphany.gschema.xml:39
msgid "List of the search engines."
msgstr "ລາຍຊື່ເຄື່ອງມືຄົ້ນຫາ."

#: data/org.gnome.epiphany.gschema.xml:40
msgid ""
"List of the search engines. It is an array of vardicts with each vardict "
"corresponding to a search engine, and with the following supported keys: "
"\"name\" is the name of the search engine. \"url\" is the search URL with "
"the search term replaced with %s. \"bang\" is the bang (shortcut word) of "
"the search engine."
msgstr ""
"ລາຍຊື່ເຄື່ອງມືຄົ້ນຫາ. ມັນແມ່ນອາເຣຂອງ vardicts ໂດຍແຕ່ລະ vardict ຈະກົງກັບເຄື່ອງມືຄົ້ນຫາ, ແລະ ຮອງຮັບຄີດັ່ງນີ້: "
"\"name\" ແມ່ນຊື່ຂອງເຄື່ອງມືຄົ້ນຫາ. \"url\" ແມ່ນ URL ສໍາລັບຄົ້ນຫາທີ່ມີຄໍາຄົ້ນຫາຖືກແທນດ້ວຍ %s. \"bang\" ແມ່ນຄໍາສັ່ງລັດ (shortcut word) ຂອງເຄື່ອງມືຄົ້ນຫາ."

#: data/org.gnome.epiphany.gschema.xml:50
msgid "Enable Search Suggestions"
msgstr "ເປີດໃຊ້ການແນະນຳການຄົ້ນຫາ"

#: data/org.gnome.epiphany.gschema.xml:51
msgid "Whether to show Search Suggestion in url entry popdown."
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງການແນະນຳການຄົ້ນຫາໃນລາຍການ URL ທີ່ປາກົດລົງມາຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:55
msgid "Force new windows to be opened in tabs"
msgstr "ບັງຄັບໃຫ້ເປີດປ່ອງຢ້ຽມໃໝ່ໃນແທັບ"

#: data/org.gnome.epiphany.gschema.xml:56
msgid ""
"Force new window requests to be opened in tabs instead of using a new window."
msgstr "ບັງຄັບໃຫ້ຄຳຮ້ອງຂໍເປີດປ່ອງຢ້ຽມໃໝ່ຖືກເປີດໃນແທັບແທນທີ່ຈະໃຊ້ປ່ອງຢ້ຽມໃໝ່."

#: data/org.gnome.epiphany.gschema.xml:63
msgid "Whether to automatically restore the last session"
msgstr "ກຳນົດວ່າຈະໃຫ້ກູ້ຄືນເຊດຊັນຫຼ້າສຸດໂດຍອັດຕະໂນມັດຫຼືບໍ່"

#: data/org.gnome.epiphany.gschema.xml:64
msgid ""
"Defines how the session will be restored during startup. Allowed values are "
"“always” (the previous state of the application is always restored) and "
"“crashed” (the session is only restored if the application crashes)."
msgstr ""
"ກຳນົດວິທີການກູ້ຄືນເຊດຊັນຕອນເລີ່ມຕົ້ນ. ຄ່າທີ່ອະນຸຍາດຄື “always” (ກູ້ຄືນສະຖານະກ່ອນໜ້າຂອງແອັບພລິເຄຊັນສະເໝີ) ແລະ “crashed” (ກູ້ຄືນເຊດຊັນສະເພາະຕອນແອັບພລິເຄຊັນຂັດຂ້ອງ)."

#: data/org.gnome.epiphany.gschema.xml:68
msgid ""
"Whether to delay loading of tabs that are not immediately visible on session "
"restore"
msgstr "ກຳນົດວ່າຈະໃຫ້ເລື່ອນການໂຫຼດແທັບທີ່ບໍ່ໄດ້ເຫັນໃນທັນທີໃນຕອນກູ້ຄືນເຊດຊັນຫຼືບໍ່"

#: data/org.gnome.epiphany.gschema.xml:69
msgid ""
"When this option is set to true, tabs will not start loading until the user "
"switches to them, upon session restore."
msgstr "ເມື່ອຕັ້ງຄ່ານີ້ເປັນຈິງ, ແທັບຈະຍັງບໍ່ເລີ່ມໂຫຼດຈົນກວ່າຜູ້ໃຊ້ຈະສະຫຼັບໄປຫາແທັບນັ້ນ ໃນຕອນກູ້ຄືນເຊດຊັນ."

#: data/org.gnome.epiphany.gschema.xml:73
msgid "List of adblock filters"
msgstr "ລາຍຊື່ຕົວຕອງການປິດກັ້ນໂຄສະນາ"

#: data/org.gnome.epiphany.gschema.xml:74
msgid ""
"List of URLs with content filtering rules in JSON format to be used by the "
"ad blocker."
msgstr "ລາຍຊື່ URL ທີ່ມີກົດການຕອງເນື້ອຫາໃນຮູບແບບ JSON ເພື່ອໃຊ້ສຳລັບຕົວປິດກັ້ນໂຄສະນາ."

#: data/org.gnome.epiphany.gschema.xml:78
msgid "Whether to ask for setting browser as default"
msgstr "ກຳນົດວ່າຈະໃຫ້ຖາມເພື່ອຕັ້ງຕົວທ່ອງເວັບເປັນຄ່າເລີ່ມຕົ້ນຫຼືບໍ່"

#: data/org.gnome.epiphany.gschema.xml:79
msgid ""
"When this option is set to true, browser will ask for being default if it is "
"not already set."
msgstr "ເມື່ອຕັ້ງຄ່ານີ້ເປັນຈິງ, ຕົວທ່ອງເວັບຈະຖາມເພື່ອຕັ້ງເປັນຄ່າເລີ່ມຕົ້ນ ຖ້າຍັງບໍ່ໄດ້ຕັ້ງໄວ້."

#: data/org.gnome.epiphany.gschema.xml:83
msgid "Start in incognito mode"
msgstr "ເລີ່ມຕົ້ນໃນໂໝດບໍ່ລະບຸຕົວຕົນ"

#: data/org.gnome.epiphany.gschema.xml:84
msgid ""
"When this option is set to true, browser will always start in incognito mode"
msgstr "ເມື່ອຕັ້ງຄ່ານີ້ເປັນຈິງ, ຕົວທ່ອງເວັບຈະເລີ່ມຕົ້ນໃນໂໝດບໍ່ລະບຸຕົວຕົນສະເໝີ"

#: data/org.gnome.epiphany.gschema.xml:88
msgid "Active clear data items."
msgstr "ລາຍການລຶບຂໍ້ມູນທີ່ກຳລັງໃຊ້."

#: data/org.gnome.epiphany.gschema.xml:89
msgid ""
"Selection (bitmask) which clear data items should be active by default. 1 = "
"Cookies, 2 = HTTP disk cache, 4 = Local storage data, 8 = Offline web "
"application cache, 16 = IndexDB databases, 32 = WebSQL databases, 64 = "
"Plugins data, 128 = HSTS policies cache, 256 = Intelligent Tracking "
"Prevention data."
msgstr ""
"ການເລືອກ (bitmask) ວ່າລາຍການລຶບຂໍ້ມູນໃດຄວນຈະຖືກເລືອກໄວ້ເປັນຄ່າເລີ່ມຕົ້ນ. 1 = ຄຸກກີ້, 2 = ແຄຊດິສ HTTP, 4 = ຂໍ້ມູນບ່ອນເກັບຂໍ້ມູນພາຍໃນ, 8 = ແຄຊແອັບພລິເຄຊັນເວັບແບບອອຟລາຍ, 16 = ຖານຂໍ້ມູນ IndexDB, 32 = ຖານຂໍ້ມູນ WebSQL, 64 = ຂໍ້ມູນປລັກອິນ, 128 = ແຄຊນະໂຍບາຍ HSTS, 256 = ຂໍ້ມູນການປ້ອງກັນການຕິດຕາມອັດສະລິຍະ."

#: data/org.gnome.epiphany.gschema.xml:95
msgid "Expand tabs size to fill the available space on the tabs bar."
msgstr "ຂະຫຍາຍຂະໜາດແທັບໃຫ້ເຕັມພື້ນທີ່ທີ່ມີຢູ່ໃນແຖບແທັບ."

#: data/org.gnome.epiphany.gschema.xml:96
msgid ""
"If enabled the tabs will expand to use the entire available space in the "
"tabs bar. This setting is ignored in Pantheon desktop."
msgstr "ຖ້າເປີດໃຊ້, ແທັບຈະຂະຫຍາຍອອກເພື່ອໃຊ້ພື້ນທີ່ທັງໝົດທີ່ມີຢູ່ໃນແຖບແທັບ. ຄ່ານີ້ຈະຖືກລະເວັ້ນໃນເດັສທັອບ Pantheon."

#: data/org.gnome.epiphany.gschema.xml:100
msgid "Show url bar at bottom"
msgstr "ສະແດງແຖບ URL ຢູ່ທາງລຸ່ມ"

#: data/org.gnome.epiphany.gschema.xml:101
msgid "Whether to show url bar on bottom."
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງແຖບ URL ຢູ່ທາງລຸ່ມຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:105
msgid "The visibility policy for the tabs bar."
msgstr "ນະໂຍບາຍການສະແດງຜົນຂອງແຖບແທັບ."

#: data/org.gnome.epiphany.gschema.xml:106
msgid ""
"Controls when the tabs bar is shown. Possible values are “always” (the tabs "
"bar is always shown), “more-than-one” (the tabs bar is only shown if there’s "
"two or more tabs) and “never” (the tabs bar is never shown). This setting is "
"ignored in Pantheon desktop, and “always” value is used."
msgstr ""
"ຄວບຄຸມເວລາທີ່ຈະສະແດງແຖບແທັບ. ຄ່າທີ່ເປັນໄປໄດ້ຄື “always” (ສະແດງແຖບແທັບສະເໝີ), “more-than-one” (ສະແດງແຖບແທັບສະເພາະຕອນທີ່ມີສອງແທັບຂຶ້ນໄປ) ແລະ “never” (ບໍ່ສະແດງແຖບແທັບເລີຍ). ຄ່ານີ້ຈະຖືກລະເວັ້ນໃນເດັສທັອບ Pantheon ແລະ ຈະໃຊ້ຄ່າ “always” ແທນ."

#: data/org.gnome.epiphany.gschema.xml:110
msgid "Keep window open when closing last tab"
msgstr "ເປີດປ່ອງຢ້ຽມໄວ້ເມື່ອປິດແທັບສຸດທ້າຍ"

#: data/org.gnome.epiphany.gschema.xml:111
msgid "If enabled application window is kept open when closing the last tab."
msgstr "ຖ້າເປີດໃຊ້, ປ່ອງຢ້ຽມແອັບພລິເຄຊັນຈະຍັງຄົງເປີດຢູ່ເຖິງວ່າຈະປິດແທັບສຸດທ້າຍແລ້ວກໍຕາມ."

#: data/org.gnome.epiphany.gschema.xml:115
msgid "Show the WebKit features preferences page."
msgstr "ສະແດງໜ້າການຕັ້ງຄ່າຄຸນສົມບັດຂອງ WebKit."

#: data/org.gnome.epiphany.gschema.xml:116
msgid ""
"Controls whether the preferences window shows the page which allows toggling "
"experimental and development WebKit features. This setting is ignored in "
"Tech Preview, and true is always used."
msgstr ""
"ຄວບຄຸມວ່າປ່ອງຢ້ຽມການຕັ້ງຄ່າຈະສະແດງໜ້າທີ່ອະນຸຍາດໃຫ້ເປີດປິດຄຸນສົມບັດທົດລອງ ແລະ ການພັດທະນາຂອງ WebKit ຫຼືບໍ່. ຄ່ານີ້ຈະຖືກລະເວັ້ນໃນ Tech Preview ແລະ ຈະຖືກຕັ້ງເປັນຈິງສະເໝີ."

#: data/org.gnome.epiphany.gschema.xml:120
msgid "Show internal WebKit features in the features preferences page."
msgstr "ສະແດງຄຸນສົມບັດພາຍໃນຂອງ WebKit ໃນໜ້າການຕັ້ງຄ່າຄຸນສົມບັດ."

#: data/org.gnome.epiphany.gschema.xml:121
msgid ""
"Controls whether the features page in the preferences window shows internal "
"WebKit features."
msgstr "ຄວບຄຸມວ່າໜ້າຄຸນສົມບັດໃນປ່ອງຢ້ຽມການຕັ້ງຄ່າຈະສະແດງຄຸນສົມບັດພາຍໃນຂອງ WebKit ຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:127
msgid "Reader mode article font style."
msgstr "ຮູບແບບຟອນບົດຄວາມໃນໂໝດການອ່ານ."

#: data/org.gnome.epiphany.gschema.xml:128
msgid ""
"Chooses the style of the main body text for articles in reader mode. "
"Possible values are “sans” and “serif”."
msgstr "ເລືອກຮູບແບບຂອງເນື້ອຫາຫຼັກສຳລັບບົດຄວາມໃນໂໝດການອ່ານ. ຄ່າທີ່ເປັນໄປໄດ້ຄື “sans” ແລະ “serif”."

#: data/org.gnome.epiphany.gschema.xml:132
msgid "Reader mode color scheme."
msgstr "ຊຸດສີໃນໂໝດການອ່ານ."

#: data/org.gnome.epiphany.gschema.xml:133
msgid ""
"Selects the style of colors for articles displayed in reader mode. Possible "
"values are “light” (dark text on light background) and “dark” (light text on "
"dark background). This setting is ignored on systems that provide a system-"
"wide dark style preference, such as GNOME 42 and newer."
msgstr ""
"ເລືອກຮູບແບບສີສຳລັບບົດຄວາມທີ່ສະແດງໃນໂໝດການອ່ານ. ຄ່າທີ່ເປັນໄປໄດ້ຄື “light” (ຕົວໜັງສືເຂັ້ມໃນພື້ນຫຼັງສະຫວ່າງ) ແລະ “dark” (ຕົວໜັງສືສະຫວ່າງໃນພື້ນຫຼັງເຂັ້ມ). ຄ່ານີ້ຈະຖືກລະເວັ້ນໃນລະບົບທີ່ມີການຕັ້ງຄ່າໂໝດມືດທົ່ວລະບົບ ເຊັ່ນ GNOME 42 ຫຼື ໃໝ່ກວ່າ."

#: data/org.gnome.epiphany.gschema.xml:139
msgid "Minimum font size"
msgstr "ຂະໜາດຟອນຕ່ຳສຸດ"

#: data/org.gnome.epiphany.gschema.xml:143
msgid "Use GNOME fonts"
msgstr "ໃຊ້ຟອນຂອງ GNOME"

#: data/org.gnome.epiphany.gschema.xml:144
msgid "Use GNOME font settings."
msgstr "ໃຊ້ການຕັ້ງຄ່າຟອນຂອງ GNOME."

#: data/org.gnome.epiphany.gschema.xml:148
msgid "Custom sans-serif font"
msgstr "ຟອນ Sans-serif ແບບກຳນົດເອງ"

#: data/org.gnome.epiphany.gschema.xml:149
msgid ""
"A value to be used to override sans-serif desktop font when use-gnome-fonts "
"is set."
msgstr "ຄ່າທີ່ຈະໃຊ້ແທນຟອນ sans-serif ຂອງເດັສທັອບ ເມື່ອມີການຕັ້ງຄ່າ use-gnome-fonts ໄວ້."

#: data/org.gnome.epiphany.gschema.xml:153
msgid "Custom serif font"
msgstr "ຟອນ Serif ແບບກຳນົດເອງ"

#: data/org.gnome.epiphany.gschema.xml:154
msgid ""
"A value to be used to override serif desktop font when use-gnome-fonts is "
"set."
msgstr "ຄ່າທີ່ຈະໃຊ້ແທນຟອນ serif ຂອງເດັສທັອບ ເມື່ອມີການຕັ້ງຄ່າ use-gnome-fonts ໄວ້."

#: data/org.gnome.epiphany.gschema.xml:158
msgid "Custom monospace font"
msgstr "ຟອນ Monospace ແບບກຳນົດເອງ"

#: data/org.gnome.epiphany.gschema.xml:159
msgid ""
"A value to be used to override monospace desktop font when use-gnome-fonts "
"is set."
msgstr "ຄ່າທີ່ຈະໃຊ້ແທນຟອນ monospace ຂອງເດັສທັອບ ເມື່ອມີການຕັ້ງຄ່າ use-gnome-fonts ໄວ້."

#: data/org.gnome.epiphany.gschema.xml:163
msgid "Use a custom CSS"
msgstr "ໃຊ້ CSS ແບບກຳນົດເອງ"

#: data/org.gnome.epiphany.gschema.xml:164
msgid "Use a custom CSS file to modify websites own CSS."
msgstr "ໃຊ້ໄຟລ໌ CSS ແບບກຳນົດເອງເພື່ອປັບແຕ່ງ CSS ຂອງເວັບໄຊເອງ."

#: data/org.gnome.epiphany.gschema.xml:168
msgid "Use a custom JS"
msgstr "ໃຊ້ JS ແບບກຳນົດເອງ"

#: data/org.gnome.epiphany.gschema.xml:169
msgid "Use a custom JS file to modify websites."
msgstr "ໃຊ້ໄຟລ໌ JS ແບບກຳນົດເອງເພື່ອປັບແຕ່ງເວັບໄຊ."

#: data/org.gnome.epiphany.gschema.xml:173
msgid "Enable spell checking"
msgstr "ເປີດໃຊ້ການກວດສອບຕົວສະກົດ"

#: data/org.gnome.epiphany.gschema.xml:174
msgid "Spell check any text typed in editable areas."
msgstr "ກວດສອບຕົວສະກົດໃນຂໍ້ຄວາມໃດກໍຕາມທີ່ພິມໃນພື້ນທີ່ທີ່ແກ້ໄຂໄດ້."

#: data/org.gnome.epiphany.gschema.xml:178
msgid "Default encoding"
msgstr "ການຖອດລະຫັດເລີ່ມຕົ້ນ"

#: data/org.gnome.epiphany.gschema.xml:179
msgid ""
"Default encoding. Accepted values are the ones WebKitGTK can understand."
msgstr "ການຖອດລະຫັດເລີ່ມຕົ້ນ. ຄ່າທີ່ຍອມຮັບໄດ້ຄືຄ່າທີ່ WebKitGTK ສາມາດເຂົ້າໃຈໄດ້."

#: data/org.gnome.epiphany.gschema.xml:183
#: src/resources/gtk/prefs-general-page.blp:207
msgid "Languages"
msgstr "ພາສາ"

#: data/org.gnome.epiphany.gschema.xml:184
msgid ""
"Preferred languages. Array of locale codes or “system” to use current locale."
msgstr "ພາສາທີ່ຕ້ອງການ. ອາເຣຂອງລະຫັດທ້ອງຖິ່ນ (locale) ຫຼື “system” ເພື່ອໃຊ້ຕາມລະບົບ."

#: data/org.gnome.epiphany.gschema.xml:188
msgid "Allow popups"
msgstr "ອະນຸຍາດປັອບອັບ"

#: data/org.gnome.epiphany.gschema.xml:189
msgid ""
"Allow sites to open new windows using JavaScript (if JavaScript is enabled)."
msgstr "ອະນຸຍາດໃຫ້ເວັບໄຊເປີດປ່ອງຢ້ຽມໃໝ່ໂດຍໃຊ້ JavaScript (ຖ້າເປີດໃຊ້ JavaScript ໄວ້)."

#: data/org.gnome.epiphany.gschema.xml:193
msgid "Hide cookie banner"
msgstr "ເຊື່ອງປ້າຍແຈ້ງເຕືອນຄຸກກີ້"

#: data/org.gnome.epiphany.gschema.xml:194
msgid "Hide cookie banners."
msgstr "ເຊື່ອງປ້າຍແຈ້ງເຕືອນຄຸກກີ້."

#: data/org.gnome.epiphany.gschema.xml:198
msgid "User agent"
msgstr "User agent"

#: data/org.gnome.epiphany.gschema.xml:199
msgid ""
"String that will be used as user agent, to identify the browser to the web "
"servers."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກໃຊ້ເປັນ User agent ເພື່ອລະບຸຕົວຕົນຂອງຕົວທ່ອງເວັບຕໍ່ກັບເວັບເຊີເວີ."

#: data/org.gnome.epiphany.gschema.xml:203
msgid "Enable adblock"
msgstr "ເປີດໃຊ້ການປິດກັ້ນໂຄສະນາ"

#: data/org.gnome.epiphany.gschema.xml:204
msgid ""
"Whether to block the embedded advertisements that web pages might want to "
"show."
msgstr "ກຳນົດວ່າຈະປິດກັ້ນໂຄສະນາທີ່ຝັງຢູ່ໃນໜ້າເວັບຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:208
msgid "Remember passwords"
msgstr "ຈື່ລະຫັດຜ່ານ"

#: data/org.gnome.epiphany.gschema.xml:209
msgid "Whether to store and prefill passwords in websites."
msgstr "ກຳນົດວ່າຈະໃຫ້ບັນທຶກ ແລະ ປ້ອນລະຫັດຜ່ານໃຫ້ອັດຕະໂນມັດໃນເວັບໄຊຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:213
msgid "Autofill form data"
msgstr "ປ້ອນຂໍ້ມູນໃນຟອມອັດຕະໂນມັດ"

#: data/org.gnome.epiphany.gschema.xml:214
msgid "Whether to auto fill form data in websites."
msgstr "ກຳນົດວ່າຈະໃຫ້ປ້ອນຂໍ້ມູນໃນຟອມຂອງເວັບໄຊໂດຍອັດຕະໂນມັດຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:218
msgid "Enable site-specific quirks"
msgstr "ເປີດໃຊ້ການປັບແຕ່ງສະເພາະເວັບໄຊ"

#: data/org.gnome.epiphany.gschema.xml:219
msgid ""
"Enable quirks to make specific websites work better. You might want to "
"disable this setting if debugging a specific issue."
msgstr "ເປີດໃຊ້ການປັບແຕ່ງເພື່ອໃຫ້ບາງເວັບໄຊເຮັດວຽກໄດ້ດີຂຶ້ນ. ທ່ານອາດຈະຕ້ອງການປິດຄ່ານີ້ຖ້າກຳລັງກວດສອບບັນຫາໃດໜຶ່ງຢູ່."

#: data/org.gnome.epiphany.gschema.xml:223
msgid "Enable Intelligent Tracking Prevention (ITP)"
msgstr "ເປີດໃຊ້ການປ້ອງກັນການຕິດຕາມອັດສະລິຍະ (ITP)"

#: data/org.gnome.epiphany.gschema.xml:224
msgid "Whether to enable Intelligent Tracking Prevention."
msgstr "ກຳນົດວ່າຈະເປີດໃຊ້ການປ້ອງກັນການຕິດຕາມອັດສະລິຍະຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:228
msgid "Allow websites to store local website data"
msgstr "ອະນຸຍາດໃຫ້ເວັບໄຊບັນທຶກຂໍ້ມູນເວັບໄຊພາຍໃນເຄື່ອງ"

#: data/org.gnome.epiphany.gschema.xml:229
msgid ""
"Whether to allow websites to store cookies, local storage data, and "
"IndexedDB databases. Disabling this will break many websites."
msgstr "ກຳນົດວ່າຈະອະນຸຍາດໃຫ້ເວັບໄຊບັນທຶກຄຸກກີ້, ຂໍ້ມູນບ່ອນເກັບຂໍ້ມູນພາຍໃນ ແລະ ຖານຂໍ້ມູນ IndexedDB ຫຼືບໍ່. ການປິດຄ່ານີ້ຈະເຮັດໃຫ້ຫຼາຍເວັບໄຊເຮັດວຽກຜິດພາດ."

#: data/org.gnome.epiphany.gschema.xml:233
msgid "Default zoom level for new pages"
msgstr "ລະດັບການຊູມເລີ່ມຕົ້ນສຳລັບໜ້າໃໝ່"

#: data/org.gnome.epiphany.gschema.xml:237
msgid "Default reader mode zoom level."
msgstr "ລະດັບການຊູມເລີ່ມຕົ້ນໃນໂໝດການອ່ານ."

#: data/org.gnome.epiphany.gschema.xml:238
msgid "Sets the zoom level for reader mode pages."
msgstr "ຕັ້ງລະດັບການຊູມສຳລັບໜ້າຕ່າງໆໃນໂໝດການອ່ານ."

#: data/org.gnome.epiphany.gschema.xml:242
msgid "Enable autosearch"
msgstr "ເປີດໃຊ້ການຄົ້ນຫາອັດຕະໂນມັດ"

#: data/org.gnome.epiphany.gschema.xml:243
msgid ""
"Whether to automatically search the web when something that does not look "
"like a URL is entered in the address bar. If this setting is disabled, "
"everything will be loaded as a URL unless a search engine is explicitly "
"selected from the dropdown menu."
msgstr ""
"ກຳນົດວ່າຈະຄົ້ນຫາໃນເວັບໂດຍອັດຕະໂນມັດຫຼືບໍ່ ເມື່ອມີການພິມສິ່ງທີ່ບໍ່ແມ່ນ URL ໃນແຖບທີ່ຢູ່. ຖ້າປິດຄ່ານີ້, ທຸກຢ່າງຈະຖືກໂຫຼດເປັນ URL ນອກຈາກຈະມີການເລືອກເຄື່ອງມືຄົ້ນຫາຈາກເມນູລົງມາ."

#: data/org.gnome.epiphany.gschema.xml:247
msgid "Enable mouse gestures"
msgstr "ເປີດໃຊ້ທ່າທາງຂອງເມົາສ໌ (Mouse gestures)"

#: data/org.gnome.epiphany.gschema.xml:248
msgid ""
"Whether to enable mouse gestures. Mouse gestures are based on Opera’s "
"behaviour and are activated using the middle mouse button + gesture."
msgstr "ກຳນົດວ່າຈະເປີດໃຊ້ທ່າທາງຂອງເມົາສ໌ຫຼືບໍ່. ທ່າທາງຂອງເມົາສ໌ແມ່ນອີງຕາມຮູບແບບຂອງ Opera ແລະ ເປີດໃຊ້ໂດຍການຄລິກປຸ່ມກາງຂອງເມົາສ໌ + ການເຄື່ອນໄຫວ."

#: data/org.gnome.epiphany.gschema.xml:252
msgid "Enable navigation gestures"
msgstr "ເປີດໃຊ້ທ່າທາງການນຳທາງ"

#: data/org.gnome.epiphany.gschema.xml:253
msgid "Whether to enable back and forward navigation gestures."
msgstr "ກຳນົດວ່າຈະເປີດໃຊ້ທ່າທາງການນຳທາງ ຖອຍຫຼັງ ແລະ ໄປໜ້າ ຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:257
msgid "Last upload directory"
msgstr "ໂຟນເດີອັບໂຫຼດຫຼ້າສຸດ"

#: data/org.gnome.epiphany.gschema.xml:258
msgid "Keep track of last upload directory"
msgstr "ຈື່ໂຟນເດີອັບໂຫຼດຫຼ້າສຸດ"

#: data/org.gnome.epiphany.gschema.xml:262
msgid "Last download directory"
msgstr "ໂຟນເດີດາວໂຫຼດຫຼ້າສຸດ"

#: data/org.gnome.epiphany.gschema.xml:263
msgid "Keep track of last download directory"
msgstr "ຈື່ໂຟນເດີດາວໂຫຼດຫຼ້າສຸດ"

#: data/org.gnome.epiphany.gschema.xml:267
msgid "Hardware acceleration policy"
msgstr "ນະໂຍບາຍການເລັ່ງຄວາມໄວດ້ວຍຮາດແວ"

#: data/org.gnome.epiphany.gschema.xml:268
msgid ""
"Whether to enable hardware acceleration. Possible values are “always” and "
"“never”. Hardware acceleration may be required to achieve acceptable "
"performance on embedded devices, but increases memory usage requirements and "
"could expose severe hardware-specific graphics driver bugs."
msgstr ""
"ກຳນົດວ່າຈະເປີດໃຊ້ການເລັ່ງຄວາມໄວດ້ວຍຮາດແວຫຼືບໍ່. ຄ່າທີ່ເປັນໄປໄດ້ຄື “always” ແລະ “never”. ການເລັ່ງຄວາມໄວດ້ວຍຮາດແວອາດຈຳເປັນເພື່ອໃຫ້ໄດ້ປະສິດທິພາບທີ່ດີໃນອຸປະກອນຝັງຕົວ, ແຕ່ມັນຈະເພີ່ມການໃຊ້ໜ່ວຍຄວາມຈຳ ແລະ ອາດຈະພົບຂໍ້ຜິດພາດຂອງໄດເວີກຣາບຟິກສະເພາະຮາດແວ."

#: data/org.gnome.epiphany.gschema.xml:272
msgid "Always ask for download directory"
msgstr "ຖາມບ່ອນເກັບໄຟລ໌ດາວໂຫຼດທຸກຄັ້ງ"

#: data/org.gnome.epiphany.gschema.xml:273
msgid "Whether to present a directory chooser dialog for every download."
msgstr "ກຳນົດວ່າຈະສະແດງປ່ອງຢ້ຽມເລືອກໂຟນເດີທຸກຄັ້ງທີ່ມີການດາວໂຫຼດຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:277
msgid "Enable immediately switch to new open tab"
msgstr "ເປີດໃຊ້ການສະຫຼັບໄປຫາແທັບໃໝ່ທີ່ເປີດທັນທີ"

#: data/org.gnome.epiphany.gschema.xml:278
msgid "Whether to automatically switch to a new open tab."
msgstr "ກຳນົດວ່າຈະໃຫ້ສະຫຼັບໄປຫາແທັບໃໝ່ທີ່ເປີດໂດຍອັດຕະໂນມັດຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:282
msgid "Enable WebExtensions"
msgstr "ເປີດໃຊ້ WebExtensions"

#: data/org.gnome.epiphany.gschema.xml:283
msgid ""
"Whether to enable WebExtensions. WebExtensions is a cross-browser system for "
"extensions."
msgstr "ກຳນົດວ່າຈະເປີດໃຊ້ WebExtensions ຫຼືບໍ່. WebExtensions ແມ່ນລະບົບສ່ວນຂະຫຍາຍທີ່ໃຊ້ໄດ້ກັບຫຼາຍຕົວທ່ອງເວັບ."

#: data/org.gnome.epiphany.gschema.xml:287
msgid "Active WebExtensions"
msgstr "WebExtensions ທີ່ກຳລັງໃຊ້"

#: data/org.gnome.epiphany.gschema.xml:288
msgid "Indicates which WebExtensions are set to active."
msgstr "ລະບຸວ່າ WebExtensions ໃດທີ່ຖືກຕັ້ງໃຫ້ເຮັດວຽກຢູ່."

#: data/org.gnome.epiphany.gschema.xml:292
msgid "Show developer actions"
msgstr "ສະແດງຄຳສັ່ງສຳລັບນັກພັດທະນາ"

#: data/org.gnome.epiphany.gschema.xml:293
msgid ""
"Whether to show developer context menu actions. This allows use of the Page "
"Source and Inspect Element actions."
msgstr "ກຳນົດວ່າຈະສະແດງຄຳສັ່ງນັກພັດທະນາໃນເມນູຄລິກຂວາຫຼືບໍ່. ສິ່ງນີ້ຈະຊ່ວຍໃຫ້ໃຊ້ຄຳສັ່ງ ເບິ່ງຊອດໂຄ້ດໜ້າເວັບ ແລະ ກວດສອບອົງປະກອບ ໄດ້."

#: data/org.gnome.epiphany.gschema.xml:297
msgid "Always show full URL"
msgstr "ສະແດງ URL ແບບເຕັມສະເໝີ"

#: data/org.gnome.epiphany.gschema.xml:298
msgid "Whether to show the full URL in the address bar even when unfocused."
msgstr "ກຳນົດວ່າຈະສະແດງ URL ແບບເຕັມໃນແຖບທີ່ຢູ່ ເຖິງວ່າຈະບໍ່ໄດ້ຄລິກໃສ່ກໍຕາມ."

#: data/org.gnome.epiphany.gschema.xml:302
msgid "Automatically open URIs"
msgstr "ເປີດ URI ໂດຍອັດຕະໂນມັດ"

#: data/org.gnome.epiphany.gschema.xml:303
msgid "This is a permission map of security origins to URL schemes."
msgstr "ນີ້ແມ່ນແຜນຜັງການອະນຸຍາດຂອງແຫຼ່ງຄວາມປອດໄພຕໍ່ກັບຮູບແບບ URL."

#: data/org.gnome.epiphany.gschema.xml:309
msgid "Web application additional URLs"
msgstr "URL ເພີ່ມເຕີມຂອງແອັບພລິເຄຊັນເວັບ"

#: data/org.gnome.epiphany.gschema.xml:310
msgid "The list of URLs that should be opened by the web application"
msgstr "ລາຍຊື່ URL ທີ່ຄວນຈະຖືກເປີດໂດຍແອັບພລິເຄຊັນເວັບ"

#: data/org.gnome.epiphany.gschema.xml:314
msgid "Show navigation buttons in WebApp"
msgstr "ສະແດງປຸ່ມນຳທາງໃນ WebApp"

#: data/org.gnome.epiphany.gschema.xml:315
msgid "Whether to show buttons for navigation in WebApp."
msgstr "ກຳນົດວ່າຈະສະແດງປຸ່ມນຳທາງໃນ WebApp ຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:319
msgid "Run in background"
msgstr "ເຮັດວຽກຢູ່ເບື້ອງຫຼັງ"

#: data/org.gnome.epiphany.gschema.xml:320
msgid ""
"If enabled, application continues running in the background after closing "
"the window."
msgstr "ຖ້າເປີດໃຊ້, ແອັບພລິເຄຊັນຈະຍັງຄົງເຮັດວຽກຢູ່ເບື້ອງຫຼັງຫຼັງຈາກປິດປ່ອງຢ້ຽມແລ້ວ."

#: data/org.gnome.epiphany.gschema.xml:324
msgid "WebApp is system-wide"
msgstr "WebApp ແມ່ນໃຊ້ທົ່ວລະບົບ"

#: data/org.gnome.epiphany.gschema.xml:325
msgid "If enabled, application cannot be edited or removed."
msgstr "ຖ້າເປີດໃຊ້, ແອັບພລິເຄຊັນຈະບໍ່ສາມາດແກ້ໄຂ ຫຼື ລຶບອອກໄດ້."

#: data/org.gnome.epiphany.gschema.xml:331
msgid "The downloads folder"
msgstr "ໂຟນເດີດາວໂຫຼດ"

#: data/org.gnome.epiphany.gschema.xml:332
msgid ""
"The path of the folder where to download files to; or “Downloads” to use the "
"default downloads folder, or “Desktop” to use the desktop folder."
msgstr "ເສັ້ນທາງຂອງໂຟນເດີທີ່ຈະດາວໂຫຼດໄຟລ໌ລົງໄປ; ຫຼື “Downloads” ເພື່ອໃຊ້ໂຟນເດີດາວໂຫຼດເລີ່ມຕົ້ນ, ຫຼື “Desktop” ເພື່ອໃຊ້ໂຟນເດີໜ້າຈໍ."

#: data/org.gnome.epiphany.gschema.xml:339
msgid "Window position"
msgstr "ຕຳແໜ່ງປ່ອງຢ້ຽມ"

#: data/org.gnome.epiphany.gschema.xml:340
msgid ""
"The position to use for a new window that is not restored from a previous "
"session."
msgstr "ຕຳແໜ່ງທີ່ຈະໃຊ້ສຳລັບປ່ອງຢ້ຽມໃໝ່ທີ່ບໍ່ໄດ້ກູ້ຄືນມາຈາກເຊດຊັນກ່ອນໜ້າ."

#: data/org.gnome.epiphany.gschema.xml:344
msgid "Window size"
msgstr "ຂະໜາດປ່ອງຢ້ຽມ"

#: data/org.gnome.epiphany.gschema.xml:345
msgid ""
"The size to use for a new window that is not restored from a previous "
"session."
msgstr "ຂະໜາດທີ່ຈະໃຊ້ສຳລັບປ່ອງຢ້ຽມໃໝ່ທີ່ບໍ່ໄດ້ກູ້ຄືນມາຈາກເຊດຊັນກ່ອນໜ້າ."

#: data/org.gnome.epiphany.gschema.xml:349
msgid "Is maximized"
msgstr "ຂະຫຍາຍໃຫຍ່ສຸດ"

#: data/org.gnome.epiphany.gschema.xml:350
msgid ""
"Whether a new window that is not restored from a previous session should be "
"initially maximized."
msgstr "ກຳນົດວ່າປ່ອງຢ້ຽມໃໝ່ທີ່ບໍ່ໄດ້ກູ້ຄືນມາຈາກເຊດຊັນກ່ອນໜ້າ ຄວນຈະຖືກຂະຫຍາຍໃຫຍ່ສຸດຕັ້ງແຕ່ເລີ່ມຕົ້ນຫຼືບໍ່."

#: data/org.gnome.epiphany.gschema.xml:365
msgid "Disable forward and back buttons"
msgstr "ປິດໃຊ້ປຸ່ມໄປໜ້າ ແລະ ຖອຍຫຼັງ"

#: data/org.gnome.epiphany.gschema.xml:366
msgid ""
"If set to “true”, forward and back buttons are disabled, preventing users "
"from accessing immediate browser history"
msgstr "ຖ້າຕັ້ງເປັນ “true”, ປຸ່ມໄປໜ້າ ແລະ ຖອຍຫຼັງຈະຖືກປິດໃຊ້ງານ ເພື່ອປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ເຂົ້າເຖິງປະຫວັດການທ່ອງເວັບໃນທັນທີ"

#: data/org.gnome.epiphany.gschema.xml:384
msgid "Firefox Sync Token Server URL"
msgstr "URL ເຊີເວີໂທເຄັນ Firefox Sync"

#: data/org.gnome.epiphany.gschema.xml:385
msgid "URL to a custom Firefox Sync token server."
msgstr "URL ຂອງເຊີເວີໂທເຄັນ Firefox Sync ແບບກຳນົດເອງ."

#: data/org.gnome.epiphany.gschema.xml:389
msgid "Firefox Sync Accounts Server URL"
msgstr "URL ເຊີເວີບັນຊີ Firefox Sync"

#: data/org.gnome.epiphany.gschema.xml:390
msgid "URL to a custom Firefox Sync accounts server."
msgstr "URL ຂອງເຊີເວີບັນຊີ Firefox Sync ແບບກຳນົດເອງ."

#: data/org.gnome.epiphany.gschema.xml:394
msgid "Currently signed in sync user"
msgstr "ຜູ້ໃຊ້ທີ່ກຳລັງເຂົ້າສູ່ລະບົບການຊິງຄ໌"

#: data/org.gnome.epiphany.gschema.xml:395
msgid ""
"The email linked to the Mozilla account used to sync data with Mozilla’s "
"servers."
msgstr "ອີເມລທີ່ເຊື່ອມຕໍ່ກັບບັນຊີ Mozilla ທີ່ໃຊ້ໃນການຊິງຄ໌ຂໍ້ມູນກັບເຊີເວີຂອງ Mozilla."

#: data/org.gnome.epiphany.gschema.xml:399
msgid "Last sync timestamp"
msgstr "ເວລາການຊິງຄ໌ຫຼ້າສຸດ"

#: data/org.gnome.epiphany.gschema.xml:400
msgid "The UNIX time at which last sync was made in seconds."
msgstr "ເວລາ UNIX ທີ່ໄດ້ຊິງຄ໌ຫຼ້າສຸດ (ເປັນວິນາທີ)."

#: data/org.gnome.epiphany.gschema.xml:404
msgid "Sync device ID"
msgstr "ໄອດີອຸປະກອນການຊິງຄ໌"

#: data/org.gnome.epiphany.gschema.xml:405
msgid "The sync device ID of the current device."
msgstr "ໄອດີອຸປະກອນການຊິງຄ໌ຂອງອຸປະກອນປັດຈຸບັນ."

#: data/org.gnome.epiphany.gschema.xml:409
msgid "Sync device name"
msgstr "ຊື່ອຸປະກອນການຊິງຄ໌"

#: data/org.gnome.epiphany.gschema.xml:410
msgid "The sync device name of the current device."
msgstr "ຊື່ອຸປະກອນການຊິງຄ໌ຂອງອຸປະກອນປັດຈຸບັນ."

#: data/org.gnome.epiphany.gschema.xml:414
msgid "The sync frequency in minutes"
msgstr "ຄວາມຖີ່ໃນການຊິງຄ໌ (ເປັນນາທີ)"

#: data/org.gnome.epiphany.gschema.xml:415
msgid "The number of minutes between two consecutive syncs."
msgstr "ຈຳນວນນາທີລະຫວ່າງການຊິງຄ໌ສອງຄັ້ງຕິດຕໍ່ກັນ."

#: data/org.gnome.epiphany.gschema.xml:419
msgid "Sync data with Firefox"
msgstr "ຊິງຄ໌ຂໍ້ມູນກັບ Firefox"

#: data/org.gnome.epiphany.gschema.xml:420
msgid ""
"TRUE if Ephy collections should be synced with Firefox collections, FALSE "
"otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການໃຫ້ຊິງຄ໌ຂໍ້ມູນ Ephy ກັບ Firefox, ເປັນ FALSE ຖ້າບໍ່ຕ້ອງການ."

#: data/org.gnome.epiphany.gschema.xml:424
msgid "Enable bookmarks sync"
msgstr "ເປີດໃຊ້ການຊິງຄ໌ບຸກມາກ"

#: data/org.gnome.epiphany.gschema.xml:425
msgid "TRUE if bookmarks collection should be synced, FALSE otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການໃຫ້ຊິງຄ໌ບຸກມາກ, ເປັນ FALSE ຖ້າບໍ່ຕ້ອງການ."

#: data/org.gnome.epiphany.gschema.xml:429
msgid "Bookmarks sync timestamp"
msgstr "ເວລາການຊິງຄ໌ບຸກມາກ"

#: data/org.gnome.epiphany.gschema.xml:430
msgid "The timestamp at which last bookmarks sync was made."
msgstr "ເວລາທີ່ໄດ້ຊິງຄ໌ບຸກມາກຫຼ້າສຸດ."

#: data/org.gnome.epiphany.gschema.xml:434
#: data/org.gnome.epiphany.gschema.xml:449
#: data/org.gnome.epiphany.gschema.xml:464
msgid "Initial sync or normal sync"
msgstr "ການຊິງຄ໌ເລີ່ມຕົ້ນ ຫຼື ການຊິງຄ໌ປົກກະຕິ"

#: data/org.gnome.epiphany.gschema.xml:435
msgid ""
"TRUE if bookmarks collection needs to be synced for the first time, FALSE "
"otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ບຸກມາກເປັນຄັ້ງທຳອິດ, ເປັນ FALSE ຖ້າບໍ່ແມ່ນ."

#: data/org.gnome.epiphany.gschema.xml:439
msgid "Enable passwords sync"
msgstr "ເປີດໃຊ້ການຊິງຄ໌ລະຫັດຜ່ານ"

#: data/org.gnome.epiphany.gschema.xml:440
msgid "TRUE if passwords collection should be synced, FALSE otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ລະຫັດຜ່ານ, ເປັນ FALSE ຖ້າບໍ່ຕ້ອງການ."

#: data/org.gnome.epiphany.gschema.xml:444
msgid "Passwords sync timestamp"
msgstr "ເວລາການຊິງຄ໌ລະຫັດຜ່ານ"

#: data/org.gnome.epiphany.gschema.xml:445
msgid "The timestamp at which last passwords sync was made."
msgstr "ເວລາທີ່ໄດ້ຊິງຄ໌ລະຫັດຜ່ານຫຼ້າສຸດ."

#: data/org.gnome.epiphany.gschema.xml:450
msgid ""
"TRUE if passwords collection needs to be synced for the first time, FALSE "
"otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ລະຫັດຜ່ານເປັນຄັ້ງທຳອິດ, ເປັນ FALSE ຖ້າບໍ່ແມ່ນ."

#: data/org.gnome.epiphany.gschema.xml:454
msgid "Enable history sync"
msgstr "ເປີດໃຊ້ການຊິງຄ໌ປະຫວັດ"

#: data/org.gnome.epiphany.gschema.xml:455
msgid "TRUE if history collection should be synced, FALSE otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ປະຫວັດ, ເປັນ FALSE ຖ້າບໍ່ຕ້ອງການ."

#: data/org.gnome.epiphany.gschema.xml:459
msgid "History sync timestamp"
msgstr "ເວລາການຊິງຄ໌ປະຫວັດ"

#: data/org.gnome.epiphany.gschema.xml:460
msgid "The timestamp at which last history sync was made."
msgstr "ເວລາທີ່ໄດ້ຊິງຄ໌ປະຫວັດຫຼ້າສຸດ."

#: data/org.gnome.epiphany.gschema.xml:465
msgid ""
"TRUE if history collection needs to be synced for the first time, FALSE "
"otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ປະຫວັດເປັນຄັ້ງທຳອິດ, ເປັນ FALSE ຖ້າບໍ່ແມ່ນ."

#: data/org.gnome.epiphany.gschema.xml:469
msgid "Enable open tabs sync"
msgstr "ເປີດໃຊ້ການຊິງຄ໌ແທັບທີ່ເປີດຢູ່"

#: data/org.gnome.epiphany.gschema.xml:470
msgid "TRUE if open tabs collection should be synced, FALSE otherwise."
msgstr "ເປັນ TRUE ຖ້າຕ້ອງການຊິງຄ໌ແທັບທີ່ເປີດຢູ່, ເປັນ FALSE ຖ້າບໍ່ຕ້ອງການ."

#: data/org.gnome.epiphany.gschema.xml:474
msgid "Open tabs sync timestamp"
msgstr "ເວລາການຊິງຄ໌ແທັບທີ່ເປີດຢູ່"

#: data/org.gnome.epiphany.gschema.xml:475
