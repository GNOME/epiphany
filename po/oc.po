#: data/org.gnome.Epiphany.desktop.in.in:2
#: data/org.gnome.Epiphany.metainfo.xml.in.in:6 embed/ephy-about-handler.c:205
#: embed/ephy-about-handler.c:237 src/ephy-main.c:104 src/ephy-main.c:268
#: src/ephy-main.c:429 src/window-commands.c:1230
msgid "Web"
msgstr "Web"

#: data/org.gnome.Epiphany.desktop.in.in:3
msgid "Web Browser"
msgstr "Navigador web"

#: data/org.gnome.Epiphany.desktop.in.in:4
#: data/org.gnome.Epiphany.metainfo.xml.in.in:7
msgid "Browse the web"
msgstr "Navigar sul Web"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Epiphany.desktop.in.in:6
msgid "web;browser;internet;epiphany;"
msgstr "web;navegador;navigador;navigator;internet;epiphany;"

#: data/org.gnome.Epiphany.desktop.in.in:20
msgid "New Window"
msgstr "Novèla fenèstra"

#: data/org.gnome.Epiphany.desktop.in.in:24
msgid "New Incognito Window"
msgstr "Fenèstra Incognito novèla"

#: data/org.gnome.epiphany.gschema.xml:13
msgid "Browse with caret"
msgstr "Navigar amb lo cursor"

#: data/org.gnome.epiphany.gschema.xml:17
msgid "Home page"
msgstr "Pagina d'acuèlh"

#: data/org.gnome.epiphany.gschema.xml:18
msgid "Address of the user’s home page."
msgstr "Adreça de la pagina d'acuèlh de l'utilizaire."

#: data/org.gnome.epiphany.gschema.xml:22
msgid "Default search engine"
msgstr "Motor de recèrca per defaut"

#: data/org.gnome.epiphany.gschema.xml:23
msgid "Name of the search engine selected by default."
msgstr "Nom del motor de recèrca seleccionat per defaut."

#: data/org.gnome.epiphany.gschema.xml:27
msgid "Incognito search engine"
msgstr "Motor de recèrca Incognito"

#: data/org.gnome.epiphany.gschema.xml:28
msgid "Name of the search engine selected in incognito mode."
msgstr "Nom del motor de recèrca seleccionat en mòde incognito."

#: data/org.gnome.epiphany.gschema.xml:39
msgid "List of the search engines."
msgstr "Lista dels motors de recèrca."

#: data/org.gnome.epiphany.gschema.xml:40
msgid ""
"List of the search engines. It is an array of vardicts with each vardict "
"corresponding to a search engine, and with the following supported keys: "
"\"name\" is the name of the search engine. \"url\" is the search URL with "
"the search term replaced with %s. \"bang\" is the bang (shortcut word) of "
"the search engine."
msgstr ""
"Lista dels motors de recèrca. Es una taula de vardicts ont cada vardict "
"correspond a un motor de recèrca, amb las claus seguentas suportadas : "
"« name » es lo nom del motor de recèrca. « url » es l'URL de recèrca amb lo "
"tèrme de recèrca remplaçat per %s. « bang » es lo bang (mot acorchit) del "
"motor de recèrca."

#: data/org.gnome.epiphany.gschema.xml:50
msgid "Enable Search Suggestions"
msgstr "Activar las suggestions de recèrca"

#: data/org.gnome.epiphany.gschema.xml:51
msgid "Whether to show Search Suggestion in url entry popdown."
msgstr ""
"Afichar o pas la suggestion de recèrca dins la fenèstra de sasida de l'URL."

#: data/org.gnome.epiphany.gschema.xml:55
msgid "Force new windows to be opened in tabs"
msgstr "Impausar la dobertura de las novèlas fenèstras dins un novèl onglet"

#: data/org.gnome.epiphany.gschema.xml:56
msgid ""
"Force new window requests to be opened in tabs instead of using a new window."
msgstr ""
"Impausar la dobertura de las novèlas fenèstras dins un novèl onglet al luòc "
"d'utilizar una novèla fenèstra."

#: data/org.gnome.epiphany.gschema.xml:63
msgid "Whether to automatically restore the last session"
msgstr "Indica se cal restablir automaticament la darrièra session"

#: data/org.gnome.epiphany.gschema.xml:64
msgid ""
"Defines how the session will be restored during startup. Allowed values are "
"“always” (the previous state of the application is always restored) and "
"“crashed” (the session is only restored if the application crashes)."
msgstr ""
"Definís cossí una session deu èsser restablida a l'aviada. Las valors "
"autorizadas son « always » (lo darrièr estat es totjorn restablit) e "
"« crashed » (la session es restablida solament se l’aplicacion s’es "
"arrestada brutalament)."

#: data/org.gnome.epiphany.gschema.xml:68
msgid ""
"Whether to delay loading of tabs that are not immediately visible on session "
"restore"
msgstr ""
"Definís se cal retardar lo cargament dels onglets que son pas immediatament "
"visibles al restabliment de la session"

#: data/org.gnome.epiphany.gschema.xml:69
msgid ""
"When this option is set to true, tabs will not start loading until the user "
"switches to them, upon session restore."
msgstr ""
"Al restabliment de la session e se aquesta opcion es definida a true "
"(verai), los onglets van pas començar a se cargar tant que l'utilizaire los "
"dobrís pas."

#: data/org.gnome.epiphany.gschema.xml:73
msgid "List of adblock filters"
msgstr "Lista dels filtres « adblock »"

#: data/org.gnome.epiphany.gschema.xml:74
msgid ""
"List of URLs with content filtering rules in JSON format to be used by the "
"ad blocker."
msgstr ""
"Lista d'URLs amb de règlas de filtratge de contengut al format JSON per "
"èsser utilizadas pel blocadors de publicitat."

#: data/org.gnome.epiphany.gschema.xml:78
msgid "Whether to ask for setting browser as default"
msgstr "Indica se cal demandar a definir lo navigador coma aquel per defaut"

#: data/org.gnome.epiphany.gschema.xml:79
msgid ""
"When this option is set to true, browser will ask for being default if it is "
"not already set."
msgstr ""
"Quand aquesta opcion es definida a « true », lo navigador demandarà de venir "
"navigador per defaut s'o es pas ja."

#: data/org.gnome.epiphany.gschema.xml:83
msgid "Start in incognito mode"
msgstr "Aviar en mòde incognito"

#: data/org.gnome.epiphany.gschema.xml:84
msgid ""
"When this option is set to true, browser will always start in incognito mode"
msgstr ""
"Quand aquesta opcion es definida a « true », lo navigador se dobrirà totjorn "
"en mòde de navegacion privada"

#: data/org.gnome.epiphany.gschema.xml:88
msgid "Active clear data items."
msgstr "Elements actiu pel netejatge de donadas."

#: data/org.gnome.epiphany.gschema.xml:89
msgid ""
"Selection (bitmask) which clear data items should be active by default. 1 = "
"Cookies, 2 = HTTP disk cache, 4 = Local storage data, 8 = Offline web "
"application cache, 16 = IndexDB databases, 32 = WebSQL databases, 64 = "
"Plugins data, 128 = HSTS policies cache, 256 = Intelligent Tracking "
"Prevention data."
msgstr ""
"Seleccion (masca de bits) quines elements de donadas de netejar devon èsser "
"actius per defaut. 1 = cookies, 2 = cache del disc HTTP, 4 = donadas "
"d'emmagazinatge local, 8 = cache de l'aplicacion web fòra linha, 16 = basas "
"de donadas IndexDB, 32 = basas de donadas WebSQL, 64 = donadas dels plugins, "
"128 = cache de las politicas HSTS, 256 = donadas de la prevencion "
"intelligenta del seguiment."

#: data/org.gnome.epiphany.gschema.xml:95
msgid "Expand tabs size to fill the available space on the tabs bar."
msgstr ""
"Espandir la talha dels onglets per tal d'emplenar l’espaci disponible dins "
"la barra d’onglets."

#: data/org.gnome.epiphany.gschema.xml:96
msgid ""
"If enabled the tabs will expand to use the entire available space in the "
"tabs bar. This setting is ignored in Pantheon desktop."
msgstr ""
"S’es activat, los onglets s’espandiràn per utilizar tot l’espaci disponible "
"dins la barra d’onglets. Aqueste paramètre es ignorat sul burèu Pantheon."

#: data/org.gnome.epiphany.gschema.xml:100
msgid "Show url bar at bottom"
msgstr "Afichar la barra d'adreça en bas"

#: data/org.gnome.epiphany.gschema.xml:101
msgid "Whether to show url bar on bottom."
msgstr "Indica se cal afichar la barra d'adreça en bas."

#: data/org.gnome.epiphany.gschema.xml:105
msgid "The visibility policy for the tabs bar."
msgstr "La politica de visibilitat de la barra dels onglets."

#: data/org.gnome.epiphany.gschema.xml:106
msgid ""
"Controls when the tabs bar is shown. Possible values are “always” (the tabs "
"bar is always shown), “more-than-one” (the tabs bar is only shown if there’s "
"two or more tabs) and “never” (the tabs bar is never shown). This setting is "
"ignored in Pantheon desktop, and “always” value is used."
msgstr ""
"Contròtla quand la barra d'ongletas s'aficha. Las valors possiblas son "
"« always » (la barra d'ongletas s'aficha totjorn), « more-than-one » (la "
"barra d'ongletas s'aficha sonque s'i a doas ongletas o mai) e « never » (la "
"barra d'ongletas s'aficha pas jamai). Aqueste reglatge es ignorat sul burèu "
"Pantheon, e la valor « always » es utilizada."

#: data/org.gnome.epiphany.gschema.xml:110
msgid "Keep window open when closing last tab"
msgstr "Gardar la fenèstra dobèrta en tampant lo darrièr onglet"

#: data/org.gnome.epiphany.gschema.xml:111
msgid "If enabled application window is kept open when closing the last tab."
msgstr ""
"S'es activat, la fenèstra de l'aplicacion demòra dobèrta al moment de tampar "
"lo darrièr onglet."

#: data/org.gnome.epiphany.gschema.xml:115
msgid "Show the WebKit features preferences page."
msgstr "Afichar la pagina de las preferéncias de las foncionalitats de WebKit."

#: data/org.gnome.epiphany.gschema.xml:116
msgid ""
"Controls whether the preferences window shows the page which allows toggling "
"experimental and development WebKit features. This setting is ignored in "
"Tech Preview, and true is always used."
msgstr ""
"Contròtla se la fenèstra de las preferéncias aficha la pagina que permet de "
"bascular las foncionalitats experimentalas e de desvolopament de WebKit. "
"Aqueste reglatge es ignorat dins la Tech Preview, e la valor « true » "
"(verai) es totjorn utilizada."

#: data/org.gnome.epiphany.gschema.xml:120
msgid "Show internal WebKit features in the features preferences page."
msgstr ""
"Afichar las foncionalitats intèrnas de WebKit dins la pagina de las "
"preferéncias de las foncionalitats."

#: data/org.gnome.epiphany.gschema.xml:121
msgid ""
"Controls whether the features page in the preferences window shows internal "
"WebKit features."
msgstr ""
"Contròtla se la pagina de las foncionalitats de la fenèstra de las "
"preferéncias aficha las foncionalitats intèrnas de WebKit."

#: data/org.gnome.epiphany.gschema.xml:127
msgid "Reader mode article font style."
msgstr "Estil de polissa pels articles en mòde lectura."

#: data/org.gnome.epiphany.gschema.xml:128
msgid ""
"Chooses the style of the main body text for articles in reader mode. "
"Possible values are “sans” and “serif”."
msgstr ""
"Causís l'estil del còs del tèxt principal pels articles en mòde lector. Las "
"valors possiblas son « sans » e « serif »."

#: data/org.gnome.epiphany.gschema.xml:132
msgid "Reader mode color scheme."
msgstr "Jòc de color del mòde lectura."

#: data/org.gnome.epiphany.gschema.xml:133
msgid ""
"Selects the style of colors for articles displayed in reader mode. Possible "
"values are “light” (dark text on light background) and “dark” (light text on "
"dark background). This setting is ignored on systems that provide a system-"
"wide dark style preference, such as GNOME 42 and newer."
msgstr ""
"Selecciona l'estil de las colors pels articles afichats en mòde lector. Las "
"valors possiblas son « light » (tèxte escur sus fons clar) e « dark » (tèxte "
"clar sus fons escur). Aqueste reglatge es ignorat suls sistèmas que "
"prepausan una preferéncia de mòde escur a l'escala del sistèma, coma GNOME "
"42 e las versions mai recentas."

#: data/org.gnome.epiphany.gschema.xml:139
msgid "Minimum font size"
msgstr "Talha minimala de la polissa"

#: data/org.gnome.epiphany.gschema.xml:143
msgid "Use GNOME fonts"
msgstr "Utilizar las polissas de GNOME"

#: data/org.gnome.epiphany.gschema.xml:144
msgid "Use GNOME font settings."
msgstr "Utiliza los paramètres de las polissas de GNOME."

#: data/org.gnome.epiphany.gschema.xml:148
msgid "Custom sans-serif font"
msgstr "Polissa sans serif personalizada"

#: data/org.gnome.epiphany.gschema.xml:149
msgid ""
"A value to be used to override sans-serif desktop font when use-gnome-fonts "
"is set."
msgstr ""
"Una valor a utilizar per remplaçar la polissa sans serif del burèu quand use-"
"gnome-fonts es activada."

#: data/org.gnome.epiphany.gschema.xml:153
msgid "Custom serif font"
msgstr "Polissa amb serif personalizada"

#: data/org.gnome.epiphany.gschema.xml:154
msgid ""
"A value to be used to override serif desktop font when use-gnome-fonts is "
"set."
msgstr ""
"Una valor a utilizar per remplaçar la polissa amb serif del burèu quand use-"
"gnome-fonts es activada."

#: data/org.gnome.epiphany.gschema.xml:158
msgid "Custom monospace font"
msgstr "Polissa a largor fixa personalizada"

#: data/org.gnome.epiphany.gschema.xml:159
msgid ""
"A value to be used to override monospace desktop font when use-gnome-fonts "
"is set."
msgstr ""
"Una valor a utilizar per remplaçar la polissa a largor fixa del burèu quand "
"use-gnome-fonts es activada."

#: data/org.gnome.epiphany.gschema.xml:163
msgid "Use a custom CSS"
msgstr "Utilizar un estil CSS personalizat"

#: data/org.gnome.epiphany.gschema.xml:164
msgid "Use a custom CSS file to modify websites own CSS."
msgstr ""
"Utilizar un estil CSS personalizat per modificar l'estil CSS pròpri dels "
"sites Web."

#: data/org.gnome.epiphany.gschema.xml:168
msgid "Use a custom JS"
msgstr "Utilizar un JS personalizat"

#: data/org.gnome.epiphany.gschema.xml:169
msgid "Use a custom JS file to modify websites."
msgstr "Utilizar un fichièr JS personalizat per modificar los sites Web."

#: data/org.gnome.epiphany.gschema.xml:173
msgid "Enable spell checking"
msgstr "Activar la verificacion ortografica"

#: data/org.gnome.epiphany.gschema.xml:174
msgid "Spell check any text typed in editable areas."
msgstr "Verificar l'ortografia dels tèxtes sasits dins las zònas de sasida."

#: data/org.gnome.epiphany.gschema.xml:178
msgid "Default encoding"
msgstr "Encodatge per defaut"

#: data/org.gnome.epiphany.gschema.xml:179
msgid ""
"Default encoding. Accepted values are the ones WebKitGTK can understand."
msgstr ""
"Encodatge per defaut. Las valors autorizadas son las que WebKitGTK comprend."

#: data/org.gnome.epiphany.gschema.xml:183
#: src/resources/gtk/prefs-general-page.blp:207
msgid "Languages"
msgstr "Lengas"

#: data/org.gnome.epiphany.gschema.xml:184
msgid ""
"Preferred languages. Array of locale codes or “system” to use current locale."
msgstr ""
"Lengas preferidas. Un tablèu dels còdis de las localas o « system » per "
"utilizar la locala correnta."

#: data/org.gnome.epiphany.gschema.xml:188
msgid "Allow popups"
msgstr "Autorizar las fenèstras popup"

#: data/org.gnome.epiphany.gschema.xml:189
msgid ""
"Allow sites to open new windows using JavaScript (if JavaScript is enabled)."
msgstr ""
"Autoriza los sites a dobrir de fenèstras novèlas en utilizant JavaScript (se "
"JavaScript es activat)."

#: data/org.gnome.epiphany.gschema.xml:193
msgid "Hide cookie banner"
msgstr "Rescondre la bandièra de cookies"

#: data/org.gnome.epiphany.gschema.xml:194
msgid "Hide cookie banners."
msgstr "Rescondre las bandièras de cookies."

#: data/org.gnome.epiphany.gschema.xml:198
msgid "User agent"
msgstr "Agent utilizaire"

#: data/org.gnome.epiphany.gschema.xml:199
msgid ""
"String that will be used as user agent, to identify the browser to the web "
"servers."
msgstr ""
"Cadena de caractèrs utilizada coma agent utilizaire, per fin d'identificar "
"lo navigador Web alprèp dels servidors Web."

#: data/org.gnome.epiphany.gschema.xml:203
msgid "Enable adblock"
msgstr "Activar adblock"

#: data/org.gnome.epiphany.gschema.xml:204
msgid ""
"Whether to block the embedded advertisements that web pages might want to "
"show."
msgstr ""
"Indica se cal blocar las publicitats al dintre de certanas paginas Web."

#: data/org.gnome.epiphany.gschema.xml:208
msgid "Remember passwords"
msgstr "Se remembrar dels senhals"

#: data/org.gnome.epiphany.gschema.xml:209
msgid "Whether to store and prefill passwords in websites."
msgstr ""
"Indica se cal enregistrar e pre-emplenar los senhals dins los sites Web."

#: data/org.gnome.epiphany.gschema.xml:213
msgid "Autofill form data"
msgstr "Emplenar automaticament las donadas"

#: data/org.gnome.epiphany.gschema.xml:214
msgid "Whether to auto fill form data in websites."
msgstr ""
"Se cal emplenar automaticament las donadas de formulari suls sites web."

#: data/org.gnome.epiphany.gschema.xml:218
msgid "Enable site-specific quirks"
msgstr "Activar las excentricitats especificas a un site"

#: data/org.gnome.epiphany.gschema.xml:219
msgid ""
"Enable quirks to make specific websites work better. You might want to "
"disable this setting if debugging a specific issue."
msgstr ""
"Permetre l’activacion de las excentricitats de certans sites Web per que "
"foncionen melhor. Desactivatz aqueste paramètre se volètz desbugar un "
"problèma especific."

#: data/org.gnome.epiphany.gschema.xml:223
msgid "Enable Intelligent Tracking Prevention (ITP)"
msgstr "Activar la prevencion intelligenta del seguiment (ITP)"

#: data/org.gnome.epiphany.gschema.xml:224
msgid "Whether to enable Intelligent Tracking Prevention."
msgstr "Indica se cal activar la prevencion intelligenta del seguiment."

#: data/org.gnome.epiphany.gschema.xml:228
msgid "Allow websites to store local website data"
msgstr "Autorizar los sites web a servar de donadas localas"

#: data/org.gnome.epiphany.gschema.xml:229
msgid ""
"Whether to allow websites to store cookies, local storage data, and "
"IndexedDB databases. Disabling this will break many websites."
msgstr ""
"Autorizar o non los sites web a servar de cookies, de donadas d'estocatge "
"local e de basas de donadas IndexedDB. La desactivacion d'aquesta foncion "
"empacharà nombroses sites de foncionar."

#: data/org.gnome.epiphany.gschema.xml:233
msgid "Default zoom level for new pages"
msgstr "Nivèl de zoom per defaut per las paginas novèlas"

#: data/org.gnome.epiphany.gschema.xml:237
msgid "Default reader mode zoom level."
msgstr "Nivèl de zoom per defaut del mòde lectura."

#: data/org.gnome.epiphany.gschema.xml:238
msgid "Sets the zoom level for reader mode pages."
msgstr "Definís lo nivèl de zoom per defaut de las paginas en mòde lectura."

#: data/org.gnome.epiphany.gschema.xml:242
msgid "Enable autosearch"
msgstr "Activar la recèrca automatica"

#: data/org.gnome.epiphany.gschema.xml:243
msgid ""
"Whether to automatically search the web when something that does not look "
"like a URL is entered in the address bar. If this setting is disabled, "
"everything will be loaded as a URL unless a search engine is explicitly "
"selected from the dropdown menu."
msgstr ""
"Permet de cercar automaticament sul web quand quicòm que sembla pas a una "
"URL es picat dins la barra d'adreça. Se aqueste paramètre es desactivat, tot "
"serà cargat coma una URL, levat se un motor de recèrca es seleccionat "
"explicitament dins lo menú desenrotlant."

#: data/org.gnome.epiphany.gschema.xml:247
msgid "Enable mouse gestures"
msgstr "Activar los gèstes de mirga"

#: data/org.gnome.epiphany.gschema.xml:248
msgid ""
"Whether to enable mouse gestures. Mouse gestures are based on Opera’s "
"behaviour and are activated using the middle mouse button + gesture."
msgstr ""
"Activar o non los gèstes de mirga. Los gèstes de mirga son basats sul "
"compòrtament d'Opera e s'activan en utilizant lo boton del mièg de la mirga "
"+ gèste."

#: data/org.gnome.epiphany.gschema.xml:252
msgid "Enable navigation gestures"
msgstr "Activar la navigacion amb gèstes"

#: data/org.gnome.epiphany.gschema.xml:253
msgid "Whether to enable back and forward navigation gestures."
msgstr "Se cal activar los gèstes de navigacion precedent e seguent."

#: data/org.gnome.epiphany.gschema.xml:257
msgid "Last upload directory"
msgstr "Darrièr repertòri de mandadís"

#: data/org.gnome.epiphany.gschema.xml:258
msgid "Keep track of last upload directory"
msgstr "Memorizar lo darrièr repertòri de mandadís"

#: data/org.gnome.epiphany.gschema.xml:262
msgid "Last download directory"
msgstr "Darrièr repertòri de telecargament"

#: data/org.gnome.epiphany.gschema.xml:263
msgid "Keep track of last download directory"
msgstr "Memorizar lo darrièr repertòri de telecargament"

#: data/org.gnome.epiphany.gschema.xml:267
msgid "Hardware acceleration policy"
msgstr "Politica d’acceleracion materiala"

#: data/org.gnome.epiphany.gschema.xml:268
msgid ""
"Whether to enable hardware acceleration. Possible values are “always” and "
"“never”. Hardware acceleration may be required to achieve acceptable "
"performance on embedded devices, but increases memory usage requirements and "
"could expose severe hardware-specific graphics driver bugs."
msgstr ""
"Permetre o non l'acceleracion materiala. Las valors possiblas son « always » "
"e « never ». L'acceleracion materiala pòt èsser necessària per aténher de "
"performanças acceptablas suls aparelhs embarcats, mas aumenta los besonhs en "
"memòria e poiriá revelar de bugs grèus especifics al pilòt grafic del "
"material."

#: data/org.gnome.epiphany.gschema.xml:272
msgid "Always ask for download directory"
msgstr "Totjorn demandar lo repertòri de telecargament"

#: data/org.gnome.epiphany.gschema.xml:273
msgid "Whether to present a directory chooser dialog for every download."
msgstr ""
"Indica se cal presentar una bóstia de dialòg de causida de repertòri per "
"cada telecargament."

#: data/org.gnome.epiphany.gschema.xml:277
msgid "Enable immediately switch to new open tab"
msgstr "Activar la bascula immediata a l’onglet novèl dobèrt"

#: data/org.gnome.epiphany.gschema.xml:278
msgid "Whether to automatically switch to a new open tab."
msgstr "Indica se cal bascular immediatament sus l’onglet novèl dobèrt."

#: data/org.gnome.epiphany.gschema.xml:282
msgid "Enable WebExtensions"
msgstr "Activar las WebExtensions"

#: data/org.gnome.epiphany.gschema.xml:283
msgid ""
"Whether to enable WebExtensions. WebExtensions is a cross-browser system for "
"extensions."
msgstr ""
"Activar o non las WebExtensions. Las WebExtensions son un sistèma multi-"
"navigador per las extensions."

